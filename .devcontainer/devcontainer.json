{
  "name": "Shellinator DevPod Environment - GitHub v0.0.1 Full Features",
  "image": "ubuntu:22.04",
  "features": {
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/go:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    },
    "ghcr.io/nikunh/cloudflared-vishkrm/cloudflared:0.0.4": {},
    "ghcr.io/nikunh/luarocks-vishkrm/luarocks:0.0.4": {},
    "ghcr.io/nikunh/k9s-vishkrm/k9s:0.0.4": {},
    "ghcr.io/nikunh/git-tools-vishkrm/git-tools:0.0.4": {},
    "ghcr.io/nikunh/devpod-agent-vishkrm/devpod-agent:0.0.4": {},
    "ghcr.io/nikunh/node-env-vishkrm/node-env:0.0.4": {},
    "ghcr.io/nikunh/003-zsh-setup-vishkrm/003-zsh-setup:0.0.6": {},
    "ghcr.io/nikunh/tmux-neovim-git-vishkrm/tmux-neovim-git:0.0.8": {},
    "ghcr.io/nikunh/devops-tools-vishkrm/devops-tools:0.0.5": {},
    "ghcr.io/nikunh/aider-vishkrm/aider:0.0.6": {},
    "ghcr.io/nikunh/browsh-vishkrm/browsh:0.0.5": {},
    "ghcr.io/nikunh/code-server-vishkrm/code-server:0.0.4": {},
    "ghcr.io/nikunh/dev-utils-vishkrm/dev-utils:0.0.4": {},
    "ghcr.io/nikunh/go-env-vishkrm/go-env:0.0.6": {},
    "ghcr.io/nikunh/k8s-utilities-vishkrm/k8s-utilities:0.0.6": {},
    "ghcr.io/nikunh/gui-server-vishkrm/gui-server:0.0.3": {},
    "ghcr.io/nikunh/nushell-vishkrm/nushell:0.0.4": {},
    "ghcr.io/nikunh/sops-vishkrm/sops:0.0.4": {},
    "ghcr.io/nikunh/dev-tools-additions-vishkrm/dev-tools-additions:0.0.6": {},
    "ghcr.io/nikunh/jq-likes-vishkrm/jq-likes:0.0.6": {},
    "ghcr.io/nikunh/vishkrm-config-vishkrm/vishkrm-config:0.0.8": {},
    "ghcr.io/nikunh/002-user-setup-vishkrm/002-user-setup:0.0.8": {},
    "ghcr.io/nikunh/001-dev-packages-vishkrm/001-dev-packages:0.0.20": {},
    "ghcr.io/nikunh/nas-connector-vishkrm/nas-connector:0.0.23": {},
    "ghcr.io/nikunh/capability-publisher-vishkrm/capability-publisher:0.0.1": {},
    "ghcr.io/nikunh/ai-tools-vishkrm/ai-tools:0.0.9": {}
  },
  "remoteUser": "vishkrm",
  "runArgs": [
    "--privileged",
    "-v",
    "/var/run/docker.sock:/var/run/docker.sock",
    "-p",
    "127.0.0.1:2223:2222"
  ],
  "containerEnv": {
    "HOME": "/home/vishkrm",
    "SSH_TARGET_PORT": "${localEnv:SSH_TARGET_PORT:2222}",
    "SHELLINATOR_HOST": "${localEnv:SHELLINATOR_HOST:unknown}",
    "WARP_ORG": "${localEnv:WARP_ORG}",
    "WARP_CLIENT_ID": "${localEnv:WARP_CLIENT_ID}",
    "WARP_CLIENT_SECRET": "${localEnv:WARP_CLIENT_SECRET}"
  },
  "forwardPorts": [
    2222,
    6623
  ],
  "postCreateCommand": "sudo sed -i 's/^AllowUsers .*/AllowUsers vishkrm/' /etc/ssh/sshd_config.d/devcontainer.conf && echo 'vishkrm:vishkrm' | sudo chpasswd && sudo service ssh restart; /usr/local/bin/setup-workspace-link && echo 'DevContainer ready! Shellinator GitHub v0.0.1 - Clean GitHub features loaded. SSH, nvim, tmux, code-server, AI tools available. Browsh and conda temporarily disabled. Use shellinator-enhance for private features.'",
  "postStartCommand": "warp up >/tmp/warp-autoconnect.log 2>&1 || true",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-python.debugpy",
        "visualstudioexptteam.vscodeintellicode",
        "github.copilot",
        "anthropic.claude-code",
        "formulahendry.code-runner",
        "ms-python.isort",
        "cweijan.vscode-mysql-client2",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "esbenp.prettier-vscode",
        "ms-vscode.makefile-tools",
        "ms-kubernetes-tools.vscode-kubernetes-tools",
        "yzhang.markdown-all-in-one",
        "bierner.markdown-mermaid",
        "kortina.vscode-markdown-notes",
        "ms-vscode.live-server",
        "golang.go",
        "mechatroner.rainbow-csv"
      ],
      "settings": {}
    }
  }
}
