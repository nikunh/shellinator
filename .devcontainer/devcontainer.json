{
  "name": "Shellinator DevPod Environment - Complete v0.0.12 (Shell Fix + AI Plugins)",
  "image": "ubuntu:22.04",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "babaji",
      "userUid": "1000",
      "userGid": "1000"
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    },
    "ghcr.io/nikunh/001-dev-packages-vishkrm/001-dev-packages:0.0.3": {},
    "ghcr.io/nikunh/002-user-setup-vishkrm/002-user-setup:0.0.5": {},
    "ghcr.io/nikunh/003-zsh-setup-vishkrm/003-zsh-setup:0.0.2": {},
    "ghcr.io/nikunh/tmux-neovim-git-vishkrm/tmux-neovim-git:0.0.12": {},
    "ghcr.io/devcontainers/features/conda:1": {},
    "ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {},
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/terraform:1": {},
    "ghcr.io/devcontainers/features/node:1": {
      "version": "lts"
    },
    "ghcr.io/devcontainers/features/go:1": {
      "version": "latest"
    }
  },
  "remoteUser": "babaji",
  "containerEnv": {
    "HOME": "/home/babaji",
    "SSH_TARGET_PORT": "${localEnv:SSH_TARGET_PORT:2222}"
  },
  "forwardPorts": ["${localEnv:SSH_TARGET_PORT:2222}", 6623],
  "postCreateCommand": "echo 'DevContainer ready! Welcome to Shellinator DevPod Environment - Complete v0.0.12! Shell fix v0.0.5 forces zsh default. AI plugins v0.0.12 properly installed.'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-python.debugpy",
        "visualstudioexptteam.vscodeintellicode",
        "github.copilot",
        "github.copilot-chat",
        "formulahendry.code-runner",
        "ms-python.isort",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-mysql",
        "mtxr.sqltools-driver-sqlite",
        "cweijan.vscode-mysql-client2",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "esbenp.prettier-vscode",
        "ms-vscode.makefile-tools",
        "continue.continue",
        "ex-human.model-context",
        "ms-kubernetes-tools.vscode-kubernetes-tools"
      ],
      "settings": {}
    }
  }
}