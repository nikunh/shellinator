{
  "name": "Shellinator DevPod Environment - GitHub v0.0.1 Full Features",
  "image": "ubuntu:22.04",
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2": {
      "username": "babaji",
      "userUid": "1000",
      "userGid": "1000",
      "configureZshAsDefaultShell": true
    },
    "ghcr.io/devcontainers/features/git:1": {},
    "ghcr.io/devcontainers/features/sshd:1": {
      "version": "latest"
    },
    "ghcr.io/nikunh/001-dev-packages-vishkrm/001-dev-packages:0.0.5": {},
    "ghcr.io/nikunh/002-user-setup-vishkrm/002-user-setup": {},
    "ghcr.io/nikunh/003-zsh-setup-vishkrm/003-zsh-setup": {},
    "ghcr.io/nikunh/tmux-neovim-git-vishkrm/tmux-neovim-git:0.0.5": {},
    "ghcr.io/nikunh/aider-vishkrm/aider:0.0.3": {},
    "ghcr.io/nikunh/babaji-config-vishkrm/babaji-config": {},
    "ghcr.io/nikunh/git-tools-vishkrm/git-tools": {},
    "ghcr.io/nikunh/dev-utils-vishkrm/dev-utils": {},
    "ghcr.io/nikunh/dev-tools-additions-vishkrm/dev-tools-additions": {},
    "ghcr.io/nikunh/conda-vishkrm/conda": {},
    "ghcr.io/nikunh/go-env-vishkrm/go-env": {},
    "ghcr.io/nikunh/node-env-vishkrm/node-env": {},
    "ghcr.io/nikunh/luarocks-vishkrm/luarocks": {},
    "ghcr.io/nikunh/nushell-vishkrm/nushell": {},
    "ghcr.io/nikunh/devops-tools-vishkrm/devops-tools": {},
    "ghcr.io/nikunh/k8s-utilities-vishkrm/k8s-utilities": {},
    "ghcr.io/nikunh/k9s-vishkrm/k9s": {},
    "ghcr.io/nikunh/cloudflared-vishkrm/cloudflared": {},
    "ghcr.io/nikunh/sops-vishkrm/sops": {},
    "ghcr.io/nikunh/nas-connector-vishkrm/nas-connector": {},
    "ghcr.io/nikunh/jq-likes-vishkrm/jq-likes": {},
    "ghcr.io/nikunh/gum-vishkrm/gum": {},
    "ghcr.io/nikunh/browsh-vishkrm/browsh": {},
    "ghcr.io/nikunh/ai-tools-vishkrm/ai-tools": {},
    "ghcr.io/nikunh/powerlevel10k-vishkrm/powerlevel10k": {},
    "ghcr.io/nikunh/system-personality-vishkrm/system-personality": {},
    "ghcr.io/nikunh/common-vishkrm/common": {}
  },
  "remoteUser": "babaji",
  "containerEnv": {
    "HOME": "/home/babaji",
    "SSH_TARGET_PORT": "${localEnv:SSH_TARGET_PORT:2222}"
  },
  "forwardPorts": [2222, 6623],
  "postCreateCommand": "echo 'DevContainer ready! Shellinator GitHub v0.0.1 - Fresh start with clean features. SSH, PowerLevel10k, nvim, tmux all available. Use shellinator-enhance for private features.'",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-toolsai.jupyter",
        "ms-python.debugpy",
        "visualstudioexptteam.vscodeintellicode",
        "github.copilot",
        "github.copilot-chat",
        "formulahendry.code-runner",
        "ms-python.isort",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-mysql",
        "mtxr.sqltools-driver-sqlite",
        "cweijan.vscode-mysql-client2",
        "ms-azuretools.vscode-docker",
        "redhat.vscode-yaml",
        "esbenp.prettier-vscode",
        "ms-vscode.makefile-tools",
        "continue.continue",
        "ex-human.model-context",
        "ms-kubernetes-tools.vscode-kubernetes-tools"
      ],
      "settings": {}
    }
  }
}